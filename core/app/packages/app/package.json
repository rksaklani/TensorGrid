{
    "name": "@tensorgrid/app",
    "license": "Apache-2.0",
    "version": "0.0.0",
    "private": true,
    "main": "./src/index.tsx",
    "scripts": {
        "dev": "vite",
        "build": "yarn workspace @tensorgrid/tensorgrid compile && yarn build-bare && yarn copy-to-python",
        "build:win32": "yarn workspace @tensorgrid/tensorgrid compile && yarn build-bare && yarn copy-to-python:win32",
        "build-bare": "NODE_OPTIONS=--max-old-space-size=4096 && vite build",
        "copy-to-python": "rm -rf ../../../tensorgrid/server/static && cp -r ./dist ../../../tensorgrid/server/static",
        "copy-to-python:win32": "robocopy './dist' '../../../tensorgrid/server/static' /MIR"
    },
    "dependencies": {
        "@material-ui/core": "4.12.4",
        "@tensorgrid/analytics": "*",
        "@tensorgrid/components": "*",
        "@tensorgrid/core": "*",
        "@tensorgrid/feature-flags": "*",
        "@tensorgrid/multimodal": "*",
        "@tensorgrid/relay": "*",
        "@tensorgrid/state": "*",
        "@tensorgrid/utilities": "*",
        "@use-gesture/react": "10.1.1",
        "classnames": "^2.2.6",
        "history": "^5.3.0",
        "lodash": "^4.18.1",
        "notistack": "^3.0.1",
        "numeral": "^2.0.6",
        "path-to-regexp": "^8.4.0",
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "react-error-boundary": "^3.1.4",
        "react-ga4": "^2.1.0",
        "react-is": "^17.0.1",
        "react-relay": "14.1.0",
        "react-use-measure": "^2.0.1",
        "react-uuid": "^1.0.2",
        "recoil": "0.7.7",
        "recoil-relay": "^0.1.0",
        "resize-observer-polyfill": "^1.5.1",
        "styled-components": "^6.1.8",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@types/lodash": "^4.14.182",
        "@types/mime": "^2.0.3",
        "@types/react-router": "^5.1.20",
        "@types/styled-components": "^5.1.23",
        "@vitejs/plugin-react-refresh": "^1.3.3",
        "onnxruntime-web": "^1.24.3",
        "relay-compiler": "^14.1.0",
        "rollup-plugin-polyfill-node": "^0.6.2",
        "typescript-plugin-css-modules": "^5.0.2",
        "vite": "^7.3.2",
        "vite-plugin-relay": "^1.0.7",
        "vite-plugin-rewrite-all": "^1.0.2",
        "vite-plugin-svgr": "^4.2.0",
        "vite-plugin-wasm": "^3.6.0"
    },
    "peerDependencies": {
        "@mui/icons-material": "*",
        "@react-spring/web": "*"
    }
}
